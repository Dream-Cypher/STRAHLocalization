# python venv (deps live in requirements.txt; not committed)
.venv/

# tools/ = prebuilt helper mirrored from ..\STRAHLocalizationHelper\dist\ by its
# build.ps1 (117 MB self-contained exe + native dll + config.json + pdbs). It's a
# build artifact, NOT committed here — produce it by building the sibling helper repo
# (needs .NET 8 SDK). See docs/build.md "Rebuilding the helper".
tools/

# local-scripts/ = translation grunt-work + QA tooling (LLM calls, cleanup
# passes, the review/audit/sheet pipeline). NOT needed to build the patch and
# changes frequently, so kept local-only. The repo ships only the build
# scripts in scripts/. See local-scripts/requirements.txt for its deps.
local-scripts/

# issues/ is a local working area for the translation-review pipeline. None of
# it is the source of truth (apply_review_fixes.py writes fixes into texts/en/,
# and git history of texts/en/ is the authoritative change record) -- the whole
# folder (review sheets, alignment QA dumps, gender audits, etc.) is regenerable
# scratch and is never committed.
issues/